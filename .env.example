# =====================================================================
#  Bull Machines — Manual Production Order  ·  ENVIRONMENT TEMPLATE
#  Copy this file to `.env` and fill in real values:  cp .env.example .env
#  The real `.env` is git-ignored and must NEVER be committed.
# =====================================================================

# ---- Runtime ----
ENVIRONMENT=development          # development | production
HOST=0.0.0.0
PORT=8000

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Manual_order
DB_USER=postgres
DB_PASSWORD=change-me

# ---- JWT / auth ----
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-generate-a-long-random-secret
JWT_EXPIRE_MINUTES=480

# ---- SMTP / email ----
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL=your-account@example.com
PASSWORD=your-smtp-app-password

# ---- Application ----
APP_URL=http://localhost:8000

# ---- SAP integration ----
SAP_API_URL=http://your-sap-host:8000/sap/bc/zorderapi?sap-client=900
SAP_USERNAME=change-me
SAP_PASSWORD=change-me
